# Local-only secrets. Copy this file to .env.local and fill the key there.
# Do not commit .env.local.

# Kimi Coding / Claude Code compatible endpoint.
ANTHROPIC_BASE_URL="https://api.kimi.com/coding/"
ANTHROPIC_MODEL="kimi-for-coding"
CALENZOEY_KIMI_API_KEY="replace-with-your-kimi-coding-key"

# If you prefer Claude Code style names, these are also supported when they are
# written in .env.local:
# ANTHROPIC_API_KEY="replace-with-your-kimi-coding-key"
# ANTHROPIC_AUTH_TOKEN="replace-with-your-kimi-coding-key"
